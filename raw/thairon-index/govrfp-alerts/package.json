{
  "name": "govrfp-copilot",
  "version": "1.0.0",
  "description": "Government RFP Matching SaaS Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "@turbo/gen": "^1.11.2",
    "@types/file-saver": "^2.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/govrfp-copilot"
  },
  "license": "MIT",
  "dependencies": {
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "autoprefixer": "^10.4.16",
    "bullmq": "^5.62.0",
    "file-saver": "^2.0.5",
    "googleapis": "^164.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "postcss": "^8.4.32",
    "react-email": "^4.3.2",
    "resend": "^6.3.0",
    "stripe": "^19.1.0",
    "tailwindcss": "^3.4.0",
    "xlsx": "^0.18.5"
  }
}
